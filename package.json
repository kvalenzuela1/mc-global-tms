{
  "name": "mc-global-tms",
  "version": "0.1.0-phase1",
  "private": true,
  "description": "M.C. Global Freight Solutions LLC — Phase 1 Logistics TMS (controlled pilot). Milestones 1 & 2: foundation, auth, tenant isolation, RBAC, audit.",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:reset": "node scripts/migrate.mjs --reset && node scripts/seed.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup-db": "node scripts/test-db.mjs up",
    "test:teardown-db": "node scripts/test-db.mjs down",
    "test:offline": "node --experimental-strip-types --import ./tests/_node/register.mjs --test tests/rbac.test.ts tests/driver-masking.test.ts tests/pricing.test.ts tests/compliance-gate.test.ts tests/signature-evidence.test.ts tests/invoice-eligibility.test.ts tests/lifecycle.test.ts",
    "test:db": "bash scripts/verify-db.sh"
  },
  "dependencies": {
    "@supabase/ssr": "0.5.2",
    "@supabase/supabase-js": "2.45.4",
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.0.0",
    "@types/node": "22.10.7",
    "@types/pg": "8.11.10",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "dotenv": "16.4.7",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.6",
    "pg": "8.13.1",
    "tailwindcss": "4.0.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
