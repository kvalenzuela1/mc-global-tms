# =============================================================================
# M.C. Global Freight TMS — Environment configuration (EXAMPLE)
# Copy to .env.local and fill in. NEVER commit real secrets.
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (Auth, Postgres, Storage) --------------------------------------
# From your Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key: SERVER-ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string used by migration + seed + test scripts.
# For Supabase, this is the "Connection string" (session/pooler) from the dashboard.
# For local testing, scripts/test-db.mjs provisions a throwaway database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mc_global_tms

# Separate URL used only by the automated test suite (kept isolated from dev data).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mc_global_tms_test

# --- Auth adapter ------------------------------------------------------------
# supabase (Phase 1 default) | auth0 (future adapter, not enabled in Phase 1)
AUTH_PROVIDER=supabase

# --- Notification adapter (Resend transactional email) -----------------------
# noop (Phase 1 default when unset) | resend
NOTIFICATION_PROVIDER=noop
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=dispatch@mcglobalfreightllc.com
# No paid SMS in Phase 1. SMS adapter is a disabled stub.

# --- FMCSA adapter -----------------------------------------------------------
# mock (Phase 1 default — deterministic local data) | qcmobile (future)
FMCSA_PROVIDER=mock
FMCSA_WEBKEY=

# --- Factoring adapter (packet only — NO money movement in Phase 1) ----------
FACTORING_PROVIDER=noop

# --- Feature flags -----------------------------------------------------------
# Out-of-scope adapters remain disabled in Phase 1.
FEATURE_LOAD_BOARD_SYNC=off
FEATURE_TRACKING_TELEMATICS=off
FEATURE_FACTORING_API=off
